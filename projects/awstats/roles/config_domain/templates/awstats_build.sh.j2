#!/bin/bash
set -e

# ========== CONFIGURABLE PARAMETERS ==========
DOMAINS=("{{ awstats_domains | join('" "') }}")
BASE_DOCROOT="{{ awstats_html_dir }}"
STATDIR="{{ awstats_data_dir }}"
AWSTATS_PROG="/opt/awstats/wwwroot/cgi-bin/awstats.pl"
BUILD_SCRIPT="/opt/awstats/tools/awstats_buildstaticpages.pl"
# =============================================

# Get current year and month
CUR_YEAR=$(date +%Y)
CUR_MONTH=$(date +%m)

# Process each domain sequentially
for DOMAIN in "${DOMAINS[@]}"; do
    echo "=================================================="
    echo "Starting AWStats build for domain: $DOMAIN"
    echo "=================================================="

    # NEW LOGIC: Set dynamic docroot as a subdirectory of the domain name
    DOCROOT="${BASE_DOCROOT}/${DOMAIN}"

    # Ensure the domain document root exists
    if [[ ! -d "$DOCROOT" ]]; then
        mkdir -p "$DOCROOT"
    fi

    # Iterate over all historical statistics files except for the current month
    find "$STATDIR" -type f -name "awstats*.${DOMAIN}.txt" | while read -r STATFILE; do
        BASENAME=$(basename "$STATFILE")
        FILE_MONTH=${BASENAME:7:2}
        FILE_YEAR=${BASENAME:9:4}
        FILE_ID="awstats${FILE_MONTH}${FILE_YEAR}.${DOMAIN}"

        # Skip current month
        if [[ "$FILE_MONTH" == "$CUR_MONTH" && "$FILE_YEAR" == "$CUR_YEAR" ]]; then
            continue
        fi

        TARGET_DIR="${DOCROOT}/${FILE_ID}"

        # If the output directory doesn't exist, generate the static report
        if [[ ! -d "$TARGET_DIR" ]]; then
            echo "Generating stats for $FILE_ID ..."
            mkdir -p "$TARGET_DIR"

            perl "$BUILD_SCRIPT" \
                -awstatsprog="$AWSTATS_PROG" \
                -dir="$TARGET_DIR" \
                -month=$((10#$FILE_MONTH)) \
                -year=$FILE_YEAR \
                -config="$DOMAIN" \
                -update

            # Find the main HTML file that was just generated
            MAIN_HTML="awstats.${DOMAIN}.html"

            # Create index.html in the directory with redirect (relative path to domain root)
            cat > "$TARGET_DIR/index.html" <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="refresh" content="0; url=./$MAIN_HTML" />
  <title>Redirecting to AWStats</title>
</head>
<body>
  <p>If you are not redirected automatically, follow this
     <a href="./$MAIN_HTML">link to AWStats</a>.
  </p>
</body>
</html>
EOF
            echo "Generated $TARGET_DIR and index.html"
        else
            echo "Already exists: $TARGET_DIR -> skipping"
        fi
    done

    # ========== Generate current month's statistics ==========
    echo "Generating current month's stats for $DOMAIN ..."

    perl "$BUILD_SCRIPT" \
        -awstatsprog="$AWSTATS_PROG" \
        -dir="$DOCROOT" \
        -update \
        -config="$DOMAIN"

    # Expected name for the main stats file for the current month
    MAIN_CURRENT_HTML="awstats.${DOMAIN}.html"

    # ========== Generate domain-level index.html with links ==========
    echo "Building domain index.html for $DOMAIN ..."

    INDEX_FILE="${DOCROOT}/index.html"
    {
        echo '<!DOCTYPE html>'
        echo '<html lang="en">'
        echo '<head><meta charset="UTF-8"><title>AWStats Index - '"${DOMAIN}"'</title></head>'
        echo '<body>'
        echo "<h1>AWStats Reports for ${DOMAIN}</h1>"
        echo '<p><a href="../">« Back to All Domains</a></p>'
        echo "<ul>"

        # First link: current month's summary
        echo "<li><a href=\"./${MAIN_CURRENT_HTML}\">[Current Month] ${MAIN_CURRENT_HTML}</a></li>"

        # Add links to all historical report directories (sorted descending for better UX)
        find "$DOCROOT" -mindepth 1 -maxdepth 1 -type d -name "awstats*" | sort -r | while read -r DIR; do
            DIR_NAME=$(basename "$DIR")
            echo "<li><a href=\"./${DIR_NAME}/\">${DIR_NAME}</a></li>"
        done

        echo "</ul>"
        echo '</body>'
        echo '</html>'
    } > "$INDEX_FILE"

    # Set proper ownership
#    chown -R flowers:flowers "${DOCROOT}"

    echo "Finished processing for: $DOMAIN"
    echo ""
done

# ========== NEW: Generate GLOBAL index.html for all domains ==========
echo "Building GLOBAL index.html at ${BASE_DOCROOT} ..."
GLOBAL_INDEX="${BASE_DOCROOT}/index.html"
{
    echo '<!DOCTYPE html>'
    echo '<html lang="en">'
    echo '<head><meta charset="UTF-8"><title>Global AWStats Index</title></head>'
    echo '<body>'
    echo '<h1>Available Domain Statistics</h1>'
    echo '<ul>'

    # Iterate through each domain that has a directory in BASE_DOCROOT
    for D in "${DOMAINS[@]}"; do
        if [[ -d "${BASE_DOCROOT}/${D}" ]]; then
            echo "<li><a href=\"./${D}/\">${D}</a></li>"
        fi
    done

    echo '</ul>'
    echo '</body>'
    echo '</html>'
} > "$GLOBAL_INDEX"

# chown flowers:flowers "$GLOBAL_INDEX"

echo "All reports and global index generated successfully."

